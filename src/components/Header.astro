---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";

// ✨ 核心逻辑 1：捕获当前绝对路径，提取语言标识和纯路由
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean); // 例如：['en', 'projects'] 或 ['projects']

// 判断当前所处语言
const currentLang = ['en', 'de', 'fr'].includes(segments[0]) ? segments[0] : 'cn';

// 获取去掉语言前缀后的纯页面路由（例如：'projects'、'blog' 或 ''）
const pureRoute = ['en', 'de', 'fr'].includes(segments[0]) ? segments.slice(1).join('/') : segments.join('/');

// ✨ 核心逻辑 2：动态计算语言切换按钮的跳转路径
function getLocalizedPath(targetLang: string) {
  if (targetLang === 'cn') {
    return pureRoute ? `/${pureRoute}` : '/';
  }
  return pureRoute ? `/${targetLang}/${pureRoute}` : `/${targetLang}`;
}

// ✨ 核心逻辑 3：动态计算各个栏目在当前语言环境下的正确路径
function getMenuPath(menu: string) {
  if (currentLang === 'cn') {
    return `/${menu}`;
  }
  return `/${currentLang}/${menu}`;
}

// ✨ 根据语言定义导航文字
const nav = {
  blog: currentLang === 'en' ? "Blog" : currentLang === 'de' ? "Blog" : currentLang === 'fr' ? "Blog" : "文章",
  work: currentLang === 'en' ? "Work" : currentLang === 'de' ? "Arbeit" : currentLang === 'fr' ? "Expériences" : "工作学习",
  projects: currentLang === 'en' ? "Projects" : currentLang === 'de' ? "Projekte" : currentLang === 'fr' ? "Projets" : "作品灵感",
  home: currentLang === 'en' ? "Home" : currentLang === 'de' ? "Home" : currentLang === 'fr' ? "Accueil" : "就在此处"
};
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between items-center">
      {/* 首页跳转也进行了动态语言匹配 */}
      <Link href={currentLang === 'cn' ? '/' : `/${currentLang}`} underline={false}>
        <div class="font-semibold text-black dark:text-white text-lg tracking-tight">
          {nav.home}
        </div>
      </Link>
      
      <nav class="flex gap-1 items-center text-sm">
        {/* ✨ 栏目路径全量进化为动态匹配 */}
        <Link href={getMenuPath('blog')}>{nav.blog}</Link>
        <span class="text-black/30 dark:text-white/30">/</span>
        <Link href={getMenuPath('work')}>{nav.work}</Link>
        <span class="text-black/30 dark:text-white/30">/</span>
        <Link href={getMenuPath('projects')}>{nav.projects}</Link>

        <div class="mx-4 h-6 border-l border-black/15 dark:border-white/15"></div>

        <div class="flex flex-col items-center">
          <div class="flex gap-1 text-xs text-black/60 dark:text-white/60 font-medium whitespace-nowrap">
            {/* ✨ 语言切换器全量进化为动态路径拦截替换 */}
            <Link href={getLocalizedPath('cn')} underline={false} class={currentLang === 'cn' ? 'font-bold text-black dark:text-white' : ''}>CN</Link>
            <span>/</span>
            <Link href={getLocalizedPath('en')} underline={false} class={currentLang === 'en' ? 'font-bold text-black dark:text-white' : ''}>EN</Link>
            <span>/</span>
            <Link href={getLocalizedPath('de')} underline={false} class={currentLang === 'de' ? 'font-bold text-black dark:text-white' : ''}>DE</Link>
            <span>/</span>
            <Link href={getLocalizedPath('fr')} underline={false} class={currentLang === 'fr' ? 'font-bold text-black dark:text-white' : ''}>FR</Link>
          </div>
          <span class="text-[10px] tracking-widest text-black/30 dark:text-white/30 mt-0.5 pt-0.5 border-t border-black/10 dark:border-white/10 scale-90 w-full text-center">
            language
          </span>
        </div>
      </nav>
    </div>
  </Container>
</header>
