---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@consts";
import { ViewTransitions } from 'astro:transitions';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={`${title} | ${SITE.NAME}`} description={description} />
    <ViewTransitions />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>

    <div id="music-container" style="position: fixed; bottom: 30px; right: 30px; z-index: 9999; cursor: pointer; display: flex; align-items: center; justify-content: center; width: 56px; height: 56px;">
      
      <div id="music-core" style="position: absolute; width: 12px; height: 12px; background: #1a1a1a; border-radius: 50%; z-index: 3; transition: all 0.4s ease;"></div>

      <div id="music-galaxy" style="position: absolute; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; z-index: 2; transition: all 0.3s ease;">
        <div id="music-orbits" style="color: #1a1a1a; opacity: 0.3; transform-origin: center;">
          <svg viewBox="0 0 24 24" width="44" height="44" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2.5"></circle>
          </svg>
        </div>
      </div>

      <div style="position: absolute; width: 100%; height: 100%; border-radius: 50%; border: 1px solid rgba(0,0,0,0.05);"></div>

      <audio id="bg-music" src="/audio/Opus55.mp3" loop transition:persist></audio>
    </div>

    <style is:global>
      /* 动画 A：星系自转 */
      @keyframes galaxy-rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      /* 动画 B：灵动打转（位移漂移，像眼珠打转） */
      @keyframes eye-roll {
        0%, 100% { transform: translate(0, 0); }
        25% { transform: translate(2px, -2px); }
        50% { transform: translate(-1px, 2px); }
        75% { transform: translate(-2px, -1px); }
      }

      /* 动画 C：深层呼吸（缩放 + 透明度） */
      @keyframes deep-breathe {
        0%, 100% { transform: scale(0.92); opacity: 0.3; }
        50% { transform: scale(1.08); opacity: 0.6; }
      }

      /* 初始状态：仅执行深层呼吸 */
      #music-orbits {
        animation: deep-breathe 4s ease-in-out infinite;
      }

      /* 【播放激活状态】 */
      
      /* 核心变黑变亮 */
      .playing #music-core {
        background: #000;
        box-shadow: 0 0 12px rgba(0,0,0,0.2);
        transform: scale(1.2);
      }

      /* 轨道层：叠加旋转、打转和呼吸 */
      .playing #music-orbits {
        /* 同时运行三个动画：自转(4s)、打转(5s)、呼吸(3s) */
        animation: 
          galaxy-rotate 4s linear infinite, 
          eye-roll 5s ease-in-out infinite, 
          deep-breathe 3s ease-in-out infinite !important;
        opacity: 0.9 !important;
        color: #000 !important;
      }

      /* 鼠标悬停时的微调 */
      #music-container:hover #music-core {
        transform: scale(1.3);
      }
    </style>

    <Footer />

    <script is:inline>
      function initBioMusePlayer() {
        const container = document.getElementById('music-container');
        const audio = document.getElementById('bg-music');
        
        if (!container || !audio) return;

        const refreshUI = () => {
          if (!audio.paused) {
            container.classList.add('playing');
          } else {
            container.classList.remove('playing');
          }
        };

        // 跨页面自动接力状态
        refreshUI();

        container.onclick = () => {
          if (audio.paused) {
            audio.play().then(refreshUI).catch(e => console.log("Init blocked"));
          } else {
            audio.pause();
            refreshUI();
          }
        };
      }

      // 响应 Astro 视图转换
      document.addEventListener('astro:page-load', initBioMusePlayer);
    </script>
  </body>
</html>
