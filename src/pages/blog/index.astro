---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import BackToPrev from "@components/BackToPrev.astro"; // 1. 必须引入这个组件
import { BLOG } from "@consts";

// 2. 识别当前页面语言的小逻辑
const url = Astro.url.pathname;
const isEn = url.includes('/en');
const isDe = url.includes('/de');
const isFr = url.includes('/fr');

const data = (await getCollection("blog"))
  .filter(post => {
    const isDraft = post.data.draft;
    if (isEn) return !isDraft && post.data.lang === 'en';
    if (isDe) return !isDraft && post.data.lang === 'de';
    if (isFr) return !isDraft && post.data.lang === 'fr';
    return !isDraft && (post.data.lang === 'cn' || !post.data.lang);
  })
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  
type Acc = {
  [year: string]: CollectionEntry<"blog">[];
}

const posts = data.reduce((acc: Acc, post) => {
    const year = post.data.date.getFullYear().toString();
    if (!acc[year]) {
      acc[year] = [];
    }
    acc[year].push(post);
    return acc;
  }, {});

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a)); 
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div class="animate flex gap-2 mb-10">
      {(!isEn && !isDe && !isFr) && (
        <a href="/" class="relative group w-fit flex items-center gap-1.5 px-3 py-1.5 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300 ease-in-out text-black dark:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform duration-300 ease-in-out">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          <span class="text-sm">返回主页</span>
        </a>
      )}

      <BackToPrev href="/">
        {isEn ? "Back to Home" : isDe ? "Zurück zur Startseite" : isFr ? "Retour à l'accueil" : "Back to Home"}
      </BackToPrev>
    </div>

    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">
        {isEn ? "Blog" : isDe ? "Blog" : isFr ? "Blog" : "文章"}
      </div>
      <div class="space-y-4">
        {years.map(year => (
          <section class="animate space-y-4">
            <div class="font-semibold text-black dark:text-white">
              {year}
            </div>
            <div>
              <ul class="flex flex-col gap-4">
                {
                  posts[year].map((post) => (
                    <li>
                      <ArrowCard entry={post}/>
                    </li>
                  ))
                }
              </ul>
            </div>
          </section>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>
