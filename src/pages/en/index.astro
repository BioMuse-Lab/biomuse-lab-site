---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@consts";
---

<PageLayout title="BioMuse Lab | EN" description="Digital Fortress for Scientific Inquiry and Artistic Creation">
  <Container>
    <div class="space-y-10">
      <section>
        <article class="space-y-4">
          <h4 class="animate font-semibold text-black dark:text-white">
            Right Here
          </h4>
          <p class="animate">
            Being sincere and authentic in podcasts; documenting professional insights and research methodologies in the field of Life Sciences. 
          </p>
          <p class="animate">
            Building a "Resonance Lab" that connects <strong>"Emotional Creation"</strong> with <strong>"Rational Experimentation."</strong>
          </p>
          <p class="animate">
            <em>"As all things pass through me, I gather them into my vessel."</em>
          </p>
          <p class="animate">
            Writing, scientific research, and art are all interconnected forms of expression—they are the continuous traces of life flowing within this vessel. 
          </p>
          <p class="animate">
            Welcome to my digital fortress. Let us explore the wonders of this world together.
          </p>
        </article>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Recent Posts
        </h5>
        <p class="text-sm text-black/50 dark:text-white/50 italic">
          English versions of my recent insights are currently being synchronized...
        </p>
      </section>
    </div>
  </Container>
</PageLayout>
