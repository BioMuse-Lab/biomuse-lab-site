---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";

// 🇬🇧 英文版：只精准抓取文件名以 -en 结尾的履历文件
const allwork = await getCollection("work") || [];
const work = allwork
  .filter(item => {
    if (!item || !item.id) return false;
    // 强行匹配我们在 GitHub 里创建的 -en 后缀文件
    return String(item.id).toLowerCase().endsWith("-en");
  })
  .sort((a, b) => String(a.id).localeCompare(String(b.id)));
---

<PageLayout title="Experiences" description="My professional journey.">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white text-2xl">
        Experiences
      </div>
      <ul class="flex flex-col space-y-4 animate">
        {work.map(async (entry) => {
          const { Content } = await entry.render();
          return (
            <li class="border-b border-black/10 dark:border-white/10 pb-4">
              <div class="text-sm opacity-75">
                {dateRange(entry.data.dateStart, entry.data.dateEnd)}
              </div>
              <div class="font-semibold text-black dark:text-white text-lg mt-1">
                {entry.data.company}
              </div>
              <div class="text-sm opacity-75 font-medium">
                {entry.data.role}
              </div>
              <article class="prose dark:prose-invert max-w-none text-sm mt-3">
                <Content />
              </article>
            </li>
          );
        })}
      </ul>
    </div>
  </Container>
</PageLayout>
