---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";

// 🇫🇷 Version Française : Extraction et analyse sécurisées de tous les actifs de parcours professionnels en français
const allwork = await getCollection("work") || [];

const filteredWork = allwork
  .filter(item => {
    if (!item || !item.id || !item.data) return false;
    
    // 💡 Filtrage de compatibilité : Autoriser si la balise lang est "fr", ou si le nom du fichier contient "-fr" ou le dossier "/fr/"
    const idLower = String(item.id).toLowerCase();
    const hasFrLabel = item.data.lang === "fr" || idLower.includes("-fr") || idLower.includes("/fr/");
    return hasFrLabel;
  })
  .sort((a, b) => {
    // Tri par ordre chronologique inverse (les expériences les plus récentes en premier)
    if (!a.data.dateStart || !b.data.dateStart) return 0;
    return new Date(b.data.dateStart).getTime() - new Date(a.data.dateStart).getTime();
  });

// 💡 Correctif Core : Pré-rendre tous les composants asynchrones Content dans la zone de script supérieure
const workWithContent = await Promise.all(
  filteredWork.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);
---

<PageLayout title="Parcours Professionnel" description="Mon parcours professionnel et mes expériences de vie.">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white text-2xl">
        Parcours Professionnel
      </div>
      
      {workWithContent.length > 0 ? (
        <ul class="flex flex-col space-y-4 animate">
          {workWithContent.map(({ entry, Content }) => (
            <li class="border-b border-black/10 dark:border-white/10 pb-4">
              <div class="text-sm opacity-75">
                {dateRange(entry.data.dateStart, entry.data.dateEnd)}
              </div>
              <div class="font-semibold text-black dark:text-white text-lg mt-1">
                {entry.data.company}
              </div>
              <div class="text-sm opacity-75 font-medium">
                {entry.data.role}
              </div>
              <article class="prose dark:prose-invert max-w-none text-sm mt-3">
                {/* 💡 À ce stade, Content est un composant de balise pur et directement rendu */}
                <Content />
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm italic text-black/40 dark:text-white/40">Projets créatifs en cours de préparation...</p>
      )}
    </div>
  </Container>
</PageLayout>
