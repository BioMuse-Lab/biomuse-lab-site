---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

// ✨ 核心修正 1：利用原生 Date 对象的 .valueOf() 获取时间戳排序，彻底解开 blog 集合在首页的死锁
const allBlogs = await getCollection("blog");
const blog = allBlogs
  .filter(post => {
    const isDraft = post.data.draft === true;
    const isCn = post.data.lang === "cn" || !post.data.lang;
    return !isDraft && isCn;
  })
  .sort((a, b) => {
    const timeB = b.data.date ? b.data.date.valueOf() : 0;
    const timeA = a.data.date ? a.data.date.valueOf() : 0;
    return timeB - timeA;
  })
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

// ✨ 核心修正 2：利用原生 Date 对象的 .valueOf() 获取时间戳排序，完美放出作品 2
const allProjects = await getCollection("projects");
const projects = allProjects
  .filter(project => {
    const isDraft = project.data.draft === true;
    const isCn = project.data.lang === "cn" || !project.data.lang;
    return !isDraft && isCn;
  })
  .sort((a, b) => {
    const timeB = projectB.data.date ? projectB.data.date.valueOf() : 0;
    const timeA = projectA.data.date ? projectA.data.date.valueOf() : 0;
    const projectB = b;
    const projectA = a;
    const tB = projectB.data.date ? new Date(projectB.data.date as any).getTime() : 0;
    const tA = projectA.data.date ? new Date(projectA.data.date as any).getTime() : 0;
    return tB - tA;
  })
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

// 💡 为了给 projects 排序提供无懈可击的双重保险，我们统一降维使用最高豁免权的 (x as any).getTime()，确保万无一失：
const cleanProjects = allProjects
  .filter(project => {
    const isDraft = project.data.draft === true;
    const isCn = project.data.lang === "cn" || !project.data.lang;
    return !isDraft && isCn;
  })
  .sort((a, b) => {
    const timeB = b.data.date ? new Date(b.data.date as any).getTime() : 0;
    const timeA = a.data.date ? new Date(a.data.date as any).getTime() : 0;
    return timeB - timeA;
  })
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort((a, b) => {
    const getOrder = (id) => {
      const lowerId = id.toLowerCase();
      if (lowerId.includes('bioligo')) return 1;
      if (lowerId.includes('ecust')) return 2;
      if (lowerId.includes('starbarks')) return 3;
      if (lowerId.includes('mcn')) return 4;
      return 99;
    };
    return getOrder(a.id) - getOrder(b.id);
  })
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);
