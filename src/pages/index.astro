---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

// 1. 博客流安全排序
const allBlogs = await getCollection("blog");
const blog = allBlogs
  .filter(post => {
    const isDraft = post.data.draft === true;
    const lang = post.data.lang || "";
    const isForeign = lang === "en" || lang === "de" || lang === "fr";
    return !isDraft && !isForeign;
  })
  .sort((a, b) => {
    const timeB = b.data.date ? b.data.date.valueOf() : 0;
    const timeA = a.data.date ? a.data.date.valueOf() : 0;
    return timeB - timeA;
  })
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

// 2. 作品灵感流绝对安全排序（完美托举新老作品显形）
const allProjects = await getCollection("projects");
const projects = allProjects
  .filter(project => {
    const isDraft = project.data.draft === true;
    const lang = project.data.lang || "";
    const isForeign = lang === "en" || lang === "de" || lang === "fr";
    return !isDraft && !isForeign;
  })
  .sort((a, b) => {
    const timeB = b.data.date ? b.data.date.valueOf() : 0;
    const timeA = a.data.date ? a.data.date.valueOf() : 0;
    return timeB - timeA;
  })
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort((a, b) => {
    const getOrder = (id) => {
      const lowerId = id.toLowerCase();
      if (lowerId.includes('bioligo')) return 1;
      if (lowerId.includes('ecust')) return 2;
      if (lowerId.includes('starbarks')) return 3;
      if (lowerId.includes('mcn')) return 4;
      return 99;
    };
    return getOrder(a.id) - getOrder(b.id);
  })
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    try {
      const { Content } = await item.render();
      return { ...item, Content };
    } catch (e) {
      return { ...item, Content: null };
    }
  })
);
---

