---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";

const allProjects = await getCollection("projects");

// ✨ 核心修正：放弃 localeCompare，用最高防御级别的 .getTime() 时间戳直接作差排序
const projects = allProjects
  .filter(project => project.data.lang === "cn") // 👈 英文页改成 "en" / 德文 "de" / 法文 "fr"
  .sort((a, b) => {
    const timeB = new Date(b.data.date as any).getTime();
    const timeA = new Date(a.data.date as any).getTime();
    return timeB - timeA;
  });
---

<PageLayout title="作品灵感" description="创造与实验的灵感集合。">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white text-2xl">
        作品灵感
      </div>
      <ul class="animate flex flex-col gap-4">
        {
          projects.map((project) => (
            <li>
              <ArrowCard entry={project}/>
            </li>
          ))
        }
      </ul>
      
      {projects.length === 0 && (
        <p class="text-sm text-black/50 dark:text-white/50 italic animate">
          暂无作品灵感。尽请期待。
        </p>
      )}
    </div>
  </Container>
</PageLayout>
