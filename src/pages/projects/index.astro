---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";

// ✨ 核心数据流：读取真实的本地集合名称 'projects'
const allProjects = await getCollection("projects");

// ✨ 顶级防御排序：不管 data.date 是 String 还是 Date 对象，统一强制包裹 new Date() 确保安全
const projects = allProjects
  .filter(project => project.data.lang === "cn")
  .sort((a, b) => {
    const timeB = new Date(b.data.date).getTime();
    const timeA = new Date(a.data.date).getTime();
    return timeB - timeA;
  });
---

<PageLayout title="作品灵感" description="创造与实验的灵感集合。">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white text-2xl">
        作品灵感
      </div>
      <ul class="animate flex flex-col gap-4">
        {
          projects.map((project) => (
            <li>
              <ArrowCard entry={project}/>
            </li>
          ))
        }
      </ul>
      
      {projects.length === 0 && (
        <p class="text-sm text-black/50 dark:text-white/50 italic animate">
          暂无作品灵感。尽请期待。
        </p>
      )}
    </div>
  </Container>
</PageLayout>
