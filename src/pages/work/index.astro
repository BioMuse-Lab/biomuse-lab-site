---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";

// 🇨🇳 中文版页面元数据配置
const WORK = {
  TITLE: "工作与学习履历",
  DESCRIPTION: "在生命科学领域的职业心得、销售沉淀与科研思路，构建感性创作与理性实验的共振实验室。"
};

// 🇨🇳 中文版：极其严格的兜底清洗过滤
const allwork = await getCollection("work") || [];
const work = allwork
  .filter(item => {
    // 物理防爆层：如果文件对象不存在、或者核心 id 缺失，直接安全剔除，绝不引发编译坍塌
    if (!item || !item.id) return false;
    
    const id = String(item.id).toLowerCase();
    
    // 明确排除带有 -en, -de, -fr 后缀的海外翻译文件
    const isEnglish = id.endsWith("-en");
    const isGerman = id.endsWith("-de");
    const isFrench = id.endsWith("-fr");
    
    return !isEnglish && !isGerman && !isFrench;
  })
  .sort((a, b) => {
    if (!a || !b || !a.id || !b.id) return 0;
    // 按文件名开头的数字 01, 02 排序
    return String(a.id).localeCompare(String(b.id));
  });
---
