---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";

// 🇨🇳 中文版页面元数据配置（彻底解决任何未定义报错）
const WORK = {
  TITLE: "工作与学习履历",
  DESCRIPTION: "在生命科学领域的职业心得、销售沉淀与科研思路，构建感性创作与理性实验的共振实验室。"
};

// 🇨🇳 中文版：不设限智能清洗流
const allwork = await getCollection("work") || [];
const work = allwork
  .filter(item => {
    // 1. 安全守卫：如果条目本身不存在，或者缺失关键数据，直接安全过滤
    if (!item || !item.id) return false;
    
    // 2. 核心：强制转换为全小写进行严苛判断，彻底斩断 Windows/Linux 的大小写命名死锁
    const id = String(item.id).toLowerCase();
    
    // 3. 拦截任何带有海外后缀的翻译资产
    if (id.endsWith("-en") || id.endsWith("-de") || id.endsWith("-fr")) {
      return false;
    }
    
    // 4. 放行你当前标准的 `01-bioligo`、`02-ecust`、`03-starbarks` 等原生中文履历
    return true;
  })
  .sort((a, b) => {
    if (!a || !b || !a.id || !b.id) return 0;
    // 排序同样使用小写化对齐
    return String(a.id).toLowerCase().localeCompare(String(b.id).toLowerCase());
  });
---
